---
const navLinks = [
  { label: 'Services', href: '#services' },
  { label: 'Our Work', href: '#before-after' },
  { label: 'Why Us', href: '#why-us' },
  { label: 'Process', href: '#process' },
  { label: 'FAQ', href: '#faq' },
];

const services = [
  'Roof Repair',
  'Roof Restoration',
  'Roof Replacement',
  'New Construction',
  'Free Inspections',
  'Storm Damage Assessment',
];
---

<footer class="bg-[#070B14] rounded-t-3xl">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="#" class="flex items-center gap-2.5 mb-4">
          <img src="/logo.png" alt="All Florida Construction & Roofing Co." class="w-12 h-12 object-contain" />
          <div>
            <span class="font-heading font-bold text-white text-lg leading-none block">All Florida</span>
            <span class="text-white/60 text-xs font-medium tracking-wider uppercase leading-none">Construction & Roofing</span>
          </div>
        </a>
        <p class="text-slate-400 text-sm leading-relaxed mb-6">
          Florida's flat roof specialists. Licensed, insured, and state-certified. Serving warehouses, commercial properties, and homes across Florida since 2013.
        </p>
        <!-- Social links -->
        <div class="flex items-center gap-3">
          <a href="https://www.facebook.com/profile.php?id=61572143811923" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-9 h-9 rounded-lg border border-slate-700 hover:border-white/20 hover:bg-white/10 flex items-center justify-center text-slate-400 hover:text-white transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Quick Links</h4>
        <ul class="space-y-3">
          {navLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="text-slate-400 hover:text-white text-sm transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Services</h4>
        <ul class="space-y-3">
          {services.map((service) => (
            <li>
              <span class="text-slate-400 text-sm">{service}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contact Us</h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+17864496646" class="text-slate-300 hover:text-white transition-colors text-sm font-medium">
              (786) 449-6646
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@alflaconstructions.com" class="text-slate-300 hover:text-white transition-colors text-sm break-all">
              info@alflaconstructions.com
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-slate-400 text-sm">
              Serving All of Florida, FL
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-slate-500 text-sm text-center sm:text-left">
        © {new Date().getFullYear()} All Florida Construction & Roofing Co. All rights reserved. Miami-Dade Licensed.
      </p>
      <div class="flex items-center gap-6">
        <a href="#" class="text-slate-500 hover:text-slate-300 text-xs transition-colors">Privacy Policy</a>
        <a href="#" class="text-slate-500 hover:text-slate-300 text-xs transition-colors">Terms of Service</a>
        <a href="#" class="text-slate-500 hover:text-slate-300 text-xs transition-colors">License #123456</a>
      </div>
    </div>
  </div>
</footer>
