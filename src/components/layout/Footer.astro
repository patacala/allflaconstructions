---
const navLinks = [
  { label: 'Services', href: '#services' },
  { label: 'Our Work', href: '#gallery' },
  { label: 'Why Us', href: '#why-us' },
  { label: 'Process', href: '#process' },
  { label: 'FAQ', href: '#faq' },
];

const services = [
  'Roof Installation',
  'Roof Restoration',
  'Roof Replacement',
  'Maintenance & Repair',
  'Free Inspections',
];
---

<footer class="bg-[#070B14] border-t border-brand-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="#" class="flex items-center gap-2.5 mb-4">
          <div class="w-9 h-9 bg-orange-500 rounded-lg flex items-center justify-center font-heading font-black text-white text-lg">
            A
          </div>
          <div>
            <span class="font-heading font-bold text-white text-lg leading-none block">Alfla</span>
            <span class="text-orange-400 text-xs font-medium tracking-wider uppercase leading-none">Constructions</span>
          </div>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed mb-6">
          Trusted roofing experts serving your community. Licensed, insured, and committed to quality workmanship backed by a solid guarantee.
        </p>
        <!-- Social links -->
        <div class="flex items-center gap-3">
          <a href="#" aria-label="Facebook" class="w-9 h-9 rounded-lg border border-brand-border hover:border-orange-500/50 hover:bg-orange-500/10 flex items-center justify-center text-gray-400 hover:text-orange-400 transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" aria-label="Instagram" class="w-9 h-9 rounded-lg border border-brand-border hover:border-orange-500/50 hover:bg-orange-500/10 flex items-center justify-center text-gray-400 hover:text-orange-400 transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="#" aria-label="Google" class="w-9 h-9 rounded-lg border border-brand-border hover:border-orange-500/50 hover:bg-orange-500/10 flex items-center justify-center text-gray-400 hover:text-orange-400 transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Quick Links</h4>
        <ul class="space-y-3">
          {navLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="text-gray-400 hover:text-orange-400 text-sm transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Services</h4>
        <ul class="space-y-3">
          {services.map((service) => (
            <li>
              <span class="text-gray-400 text-sm">{service}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contact Us</h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-orange-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+15550000000" class="text-gray-300 hover:text-orange-400 transition-colors text-sm font-medium">
              (555) 000-0000
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-orange-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@alflaconstructions.com" class="text-gray-300 hover:text-orange-400 transition-colors text-sm break-all">
              info@alflaconstructions.com
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-orange-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-gray-400 text-sm">
              Serving the Greater Metropolitan Area
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-brand-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-sm text-center sm:text-left">
        © {new Date().getFullYear()} Alfla Constructions. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href="#" class="text-gray-500 hover:text-gray-300 text-xs transition-colors">Privacy Policy</a>
        <a href="#" class="text-gray-500 hover:text-gray-300 text-xs transition-colors">Terms of Service</a>
        <a href="#" class="text-gray-500 hover:text-gray-300 text-xs transition-colors">License #123456</a>
      </div>
    </div>
  </div>
</footer>
