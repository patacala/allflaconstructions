---
// Native HTML5 <dialog> modal — branded with n8n webhook integration
---

<dialog
  id="contact-modal"
  class="w-full max-w-md mx-auto rounded-2xl bg-white border border-gray-200 p-0 shadow-2xl backdrop:bg-black/60 backdrop:backdrop-blur-sm overflow-hidden"
>
  <!-- Branded navy header -->
  <div class="bg-brand-navy px-6 pt-6 pb-5">
    <div class="flex items-start justify-between">
      <div class="flex items-center gap-3">
        <img src="/logo.png" alt="All Florida Construction" class="w-9 h-9 object-contain" />
        <div>
          <span class="font-heading font-bold text-white text-base leading-none block">All Florida</span>
          <span class="text-white/60 text-xs font-medium tracking-wider uppercase leading-none">Construction & Roofing</span>
        </div>
      </div>
      <button
        id="close-modal"
        aria-label="Close modal"
        class="text-white/50 hover:text-white transition-colors p-1 rounded-lg hover:bg-white/10 -mt-0.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="mt-4">
      <h3 class="text-xl font-heading font-bold text-white">Get Your Free Roof Inspection</h3>
      <p class="text-white/60 text-sm mt-1">We'll contact you within 24 hours — no commitment required.</p>
    </div>
  </div>

  <!-- Form body -->
  <div class="p-6">
    <!-- Form -->
    <form id="contact-form" class="space-y-4" novalidate>
      <div>
        <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">Full Name *</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="John Smith"
          class="w-full px-4 py-3 rounded-lg bg-white border border-gray-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange transition-colors"
        />
      </div>

      <div>
        <label for="phone" class="block text-sm font-medium text-slate-700 mb-1.5">Phone Number *</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          required
          placeholder="(786) 449-6646"
          class="w-full px-4 py-3 rounded-lg bg-white border border-gray-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange transition-colors"
        />
      </div>

      <div>
        <label for="service" class="block text-sm font-medium text-slate-700 mb-1.5">Service Needed</label>
        <select
          id="service"
          name="service"
          class="w-full px-4 py-3 rounded-lg bg-white border border-gray-200 text-slate-900 focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange transition-colors"
        >
          <option value="">Select a service...</option>
          <option value="inspection">Free Roof Inspection</option>
          <option value="restoration">Roof Restoration (Tropical 924)</option>
          <option value="repair">Roof Repair</option>
          <option value="replacement">Roof Replacement</option>
        </select>
      </div>

      <!-- Error message (hidden by default) -->
      <div id="form-error" class="hidden px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">
        Something went wrong. Please call us at <a href="tel:+17864496646" class="font-semibold underline">(786) 449-6646</a>.
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full py-4 bg-brand-orange hover:bg-orange-700 text-white font-semibold rounded-xl transition-all duration-200 shadow-md shadow-orange-500/20 hover:shadow-orange-500/35 active:scale-[0.98] mt-2 flex items-center justify-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed"
      >
        <span id="submit-label">Send Request — It's Free</span>
        <svg id="submit-spinner" class="hidden animate-spin w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
      </button>

      <p class="text-xs text-slate-400 text-center">
        No spam. We'll only call to schedule your inspection.
      </p>
    </form>

    <!-- Success state (hidden by default) -->
    <div id="form-success" class="hidden text-center py-6">
      <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h4 class="text-xl font-bold text-brand-navy mb-2">Request Received!</h4>
      <p class="text-slate-500 text-sm">We'll reach out within 24 hours to schedule your free inspection.</p>
      <p class="text-slate-400 text-xs mt-1">Or call us now: <a href="tel:+17864496646" class="text-brand-navy font-semibold hover:underline">(786) 449-6646</a></p>
      <button
        id="close-success"
        class="mt-6 px-6 py-3 bg-brand-orange hover:bg-orange-700 text-white font-semibold rounded-xl transition-colors"
      >
        Close
      </button>
    </div>
  </div>
</dialog>

<style>
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  dialog[open] {
    animation: dialogFadeIn 0.2s ease-out;
  }

  @keyframes dialogFadeIn {
    from {
      opacity: 0;
      transform: translateY(-12px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

<script>
  // ─── REPLACE THIS URL with your real n8n webhook endpoint ───
  const N8N_WEBHOOK_URL = 'https://YOUR_N8N_INSTANCE/webhook/YOUR_WEBHOOK_ID';
  // ────────────────────────────────────────────────────────────

  const modal = document.getElementById('contact-modal') as HTMLDialogElement;
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successState = document.getElementById('form-success') as HTMLElement;
  const errorState = document.getElementById('form-error') as HTMLElement;
  const closeBtn = document.getElementById('close-modal') as HTMLButtonElement;
  const closeSuccessBtn = document.getElementById('close-success') as HTMLButtonElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitLabel = document.getElementById('submit-label') as HTMLSpanElement;
  const submitSpinner = document.getElementById('submit-spinner') as SVGElement;

  // Open modal on any [data-modal="contact"] click
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('[data-modal="contact"]')) {
      modal.showModal();
    }
  });

  // Close buttons
  closeBtn?.addEventListener('click', () => modal.close());
  closeSuccessBtn?.addEventListener('click', () => {
    modal.close();
    form.classList.remove('hidden');
    successState.classList.add('hidden');
    errorState.classList.add('hidden');
    form.reset();
  });

  // Close on backdrop click
  modal?.addEventListener('click', (e) => {
    const rect = modal.getBoundingClientRect();
    const clickedOutside =
      e.clientX < rect.left ||
      e.clientX > rect.right ||
      e.clientY < rect.top ||
      e.clientY > rect.bottom;
    if (clickedOutside) modal.close();
  });

  // Form submit → n8n webhook
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorState.classList.add('hidden');

    const data = {
      name: (document.getElementById('name') as HTMLInputElement).value,
      phone: (document.getElementById('phone') as HTMLInputElement).value,
      service: (document.getElementById('service') as HTMLSelectElement).value,
      source: 'website-contact-form',
      timestamp: new Date().toISOString(),
    };

    // Loading state
    submitBtn.disabled = true;
    submitLabel.textContent = 'Sending...';
    submitSpinner.classList.remove('hidden');

    try {
      const res = await fetch(N8N_WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      // Success
      form.classList.add('hidden');
      successState.classList.remove('hidden');
    } catch (err) {
      console.error('[ContactForm] Webhook error:', err);
      errorState.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitLabel.textContent = "Send Request — It's Free";
      submitSpinner.classList.add('hidden');
    }
  });
</script>
