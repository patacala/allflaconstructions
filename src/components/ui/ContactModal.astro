---
// Native HTML5 <dialog> modal — minimal JS, no extra dependencies
---

<dialog
  id="contact-modal"
  class="w-full max-w-md mx-auto rounded-2xl bg-brand-dark border border-brand-border p-0 backdrop:bg-black/70 backdrop:backdrop-blur-sm open:animate-[fadeIn_0.2s_ease-out]"
>
  <div class="p-6 md:p-8">
    <!-- Header -->
    <div class="flex items-start justify-between mb-6">
      <div>
        <h3 class="text-2xl font-heading font-bold text-white">Get Your Free Inspection</h3>
        <p class="text-gray-400 text-sm mt-1">We'll contact you within 24 hours</p>
      </div>
      <button
        id="close-modal"
        aria-label="Close modal"
        class="text-gray-400 hover:text-white transition-colors p-1 rounded-lg hover:bg-white/10"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Form -->
    <form id="contact-form" class="space-y-4">
      <div>
        <label for="name" class="block text-sm font-medium text-gray-300 mb-1.5">Full Name *</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="John Smith"
          class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border text-white placeholder-gray-500 focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-colors"
        />
      </div>

      <div>
        <label for="phone" class="block text-sm font-medium text-gray-300 mb-1.5">Phone Number *</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          required
          placeholder="(555) 000-0000"
          class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border text-white placeholder-gray-500 focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-colors"
        />
      </div>

      <div>
        <label for="service" class="block text-sm font-medium text-gray-300 mb-1.5">Service Needed</label>
        <select
          id="service"
          name="service"
          class="w-full px-4 py-3 rounded-lg bg-brand-navy border border-brand-border text-white focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-colors"
        >
          <option value="" class="bg-brand-dark">Select a service...</option>
          <option value="inspection" class="bg-brand-dark">Free Roof Inspection</option>
          <option value="installation" class="bg-brand-dark">New Roof Installation</option>
          <option value="restoration" class="bg-brand-dark">Roof Restoration</option>
          <option value="replacement" class="bg-brand-dark">Roof Replacement</option>
          <option value="maintenance" class="bg-brand-dark">Maintenance & Repair</option>
        </select>
      </div>

      <button
        type="submit"
        class="w-full py-4 bg-orange-500 hover:bg-orange-400 text-white font-semibold rounded-lg transition-all duration-200 shadow-lg shadow-orange-500/25 hover:shadow-orange-500/40 active:scale-[0.98] mt-2"
      >
        Send Request — It's Free
      </button>

      <p class="text-xs text-gray-500 text-center">
        No spam. We'll only call to schedule your inspection.
      </p>
    </form>

    <!-- Success state (hidden by default) -->
    <div id="form-success" class="hidden text-center py-6">
      <div class="text-5xl mb-4">✅</div>
      <h4 class="text-xl font-bold text-white mb-2">Request Received!</h4>
      <p class="text-gray-400">We'll reach out within 24 hours to schedule your free inspection.</p>
      <button
        id="close-success"
        class="mt-6 px-6 py-3 bg-orange-500 hover:bg-orange-400 text-white font-semibold rounded-lg transition-colors"
      >
        Close
      </button>
    </div>
  </div>
</dialog>

<style>
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
  }

  dialog[open] {
    animation: dialogFadeIn 0.2s ease-out;
  }

  @keyframes dialogFadeIn {
    from {
      opacity: 0;
      transform: translateY(-12px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

<script>
  const modal = document.getElementById('contact-modal') as HTMLDialogElement;
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successState = document.getElementById('form-success') as HTMLElement;
  const closeBtn = document.getElementById('close-modal') as HTMLButtonElement;
  const closeSuccessBtn = document.getElementById('close-success') as HTMLButtonElement;

  // Open modal from any element with data-modal="contact"
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('[data-modal="contact"]')) {
      modal.showModal();
    }
  });

  // Close buttons
  closeBtn?.addEventListener('click', () => modal.close());
  closeSuccessBtn?.addEventListener('click', () => {
    modal.close();
    form.classList.remove('hidden');
    successState.classList.add('hidden');
    form.reset();
  });

  // Close on backdrop click
  modal?.addEventListener('click', (e) => {
    const rect = modal.getBoundingClientRect();
    const clickedOutside =
      e.clientX < rect.left ||
      e.clientX > rect.right ||
      e.clientY < rect.top ||
      e.clientY > rect.bottom;
    if (clickedOutside) modal.close();
  });

  // Form submit (replace with real handler / API call)
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.classList.add('hidden');
    successState.classList.remove('hidden');
  });
</script>
