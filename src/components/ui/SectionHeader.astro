---
interface Props {
  label?: string;
  title: string;
  titleHighlight?: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { label, title, titleHighlight, subtitle, align = 'center' } = Astro.props;

const alignClass = align === 'left' ? 'text-left' : 'text-center mx-auto';
const maxW = align === 'left' ? '' : 'max-w-2xl';
---

<div class={`${alignClass} ${maxW} mb-12 lg:mb-16`}>
  {label && (
    <span class="inline-block text-brand-orange text-sm font-semibold tracking-widest uppercase mb-3">
      {label}
    </span>
  )}
  <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-black text-brand-navy leading-tight mb-4">
    {title}
    {titleHighlight && (
      <span class="text-gradient"> {titleHighlight}</span>
    )}
  </h2>
  {subtitle && (
    <p class="text-slate-600 text-lg leading-relaxed">
      {subtitle}
    </p>
  )}
</div>
