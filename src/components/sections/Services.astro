---
const services = [
  {
    title: 'Roof Repair',
    description: 'Fast, targeted repairs for leaks, damaged sections, blisters, and storm damage. We stop the problem before it spreads.',
    bullets: [
      'Emergency same-day response available',
      'Storm damage & leak repairs',
      'Detailed inspection report included',
    ],
    photo: '/service1.jpeg',
    photoAlt: 'Roofing worker on flat roof doing repairs',
    tag: null,
    featured: false,
  },
  {
    title: 'Roof Restoration',
    description: 'Premium silicone coating extends your roof life 15+ years at a fraction of replacement cost. The smart choice for Miami flat roofs.',
    bullets: [
      'Seamless silicone coating system',
      '15-year manufacturer warranty',
      'Energy savings up to 35%',
    ],
    photo: '/service2.jpeg',
    photoAlt: 'Clean white flat roof after silicone restoration',
    tag: 'Best Value — Save Up to 60%',
    featured: true,
  },
  {
    title: 'Roof Replacement',
    description: 'Full tear-off and new roof system when restoration is not an option. Premium materials, clean removal, workmanship guarantee.',
    bullets: [
      'Full tear-off & disposal included',
      'All flat roof systems available',
      'Manufacturer & workmanship warranty',
    ],
    photo: '/service3.jpeg',
    photoAlt: 'New roof installation',
    tag: null,
    featured: false,
  },
  {
    title: 'New Construction',
    description: 'Complete roofing systems for new builds — residential and commercial. From blueprint to final inspection.',
    bullets: [
      'Full build-to-spec installation',
      'All roofing systems available',
      'Florida Building Code compliant',
    ],
    photo: 'https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&w=600&q=80',
    photoAlt: 'New construction roofing in progress',
    tag: null,
    featured: false,
  },
];

const [repair, restoration, replacement, newConstr] = services;
---

<section id="services" class="pt-36 lg:pt-40 pb-24 lg:pb-32 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="text-center mb-12 lg:mb-16">
      <div class="inline-flex items-center gap-2 text-sm text-slate-500 mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
        Our Services
      </div>
      <h2 class="text-4xl lg:text-5xl font-heading font-bold text-slate-900 leading-tight mb-4">
        Florida Flat Roof Specialists
      </h2>
      <p class="text-slate-500 text-lg max-w-2xl mx-auto">
        We focus exclusively on flat roofs — repair, restoration, and replacement. No jack of all trades. Just experts.
      </p>
    </div>

    <!--
      Creative layout (desktop):
      ┌──────────────┬──────────────────────┬──────────────┐
      │  Roof Repair │  Restoration         │ Replacement  │
      │  (standard)  │  (featured, raised)  ├──────────────┤
      │              │                      │ New Constr.  │
      └──────────────┴──────────────────────┴──────────────┘
    -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.15fr_1fr] gap-5 lg:items-start">

      <!-- COL 1: Roof Repair — standard vertical card -->
      <div class="group rounded-2xl overflow-hidden border border-gray-100 bg-white shadow-sm hover:shadow-md transition-all duration-300 flex flex-col">
        <div class="overflow-hidden h-52">
          <img src={repair.photo} alt={repair.photoAlt}
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy"/>
        </div>
        <div class="p-6 flex flex-col flex-1">
          <h3 class="font-heading font-bold text-xl text-slate-900 mb-2">{repair.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed mb-5 flex-1">{repair.description}</p>
          <ul class="space-y-2 mb-6">
            {repair.bullets.map((b) => (
              <li class="flex items-center gap-2 text-sm text-slate-600">
                <svg class="w-4 h-4 text-blue-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                {b}
              </li>
            ))}
          </ul>
          <button data-modal="contact"
            class="w-full py-2.5 border border-gray-200 hover:border-slate-400 text-slate-700 text-sm font-semibold rounded-xl transition-all">
            Get Quote
          </button>
        </div>
      </div>

      <!-- COL 2: Restoration — FEATURED, raised above neighbors -->
      <div class="group relative rounded-2xl overflow-hidden border-2 border-blue-500/30 bg-white shadow-xl lg:-mt-6 lg:-mb-6 flex flex-col">
        {restoration.tag && (
          <div class="absolute top-4 left-4 z-10">
            <span class="px-3 py-1 rounded-full text-xs font-bold bg-blue-500 text-white shadow-md">
              {restoration.tag}
            </span>
          </div>
        )}
        <div class="overflow-hidden h-64">
          <img src={restoration.photo} alt={restoration.photoAlt}
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy"/>
        </div>
        <div class="p-7 flex flex-col flex-1">
          <div class="inline-flex items-center gap-1.5 text-xs text-blue-500 font-semibold mb-3">
            <span class="w-1 h-1 rounded-full bg-blue-500"></span> Most Popular
          </div>
          <h3 class="font-heading font-bold text-2xl text-slate-900 mb-3">{restoration.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed mb-5 flex-1">{restoration.description}</p>
          <ul class="space-y-2 mb-7">
            {restoration.bullets.map((b) => (
              <li class="flex items-center gap-2 text-sm text-slate-600">
                <svg class="w-4 h-4 text-blue-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                {b}
              </li>
            ))}
          </ul>
          <button data-modal="contact"
            class="inline-flex items-center justify-center gap-2 pl-5 pr-1.5 py-1.5 bg-slate-900 hover:bg-slate-800 text-white text-sm font-semibold rounded-full transition-all w-full">
            Get Quote
            <span class="w-6 h-6 rounded-full bg-blue-500 flex items-center justify-center flex-shrink-0 ml-auto">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 12h14m-7-7l7 7-7 7"/>
              </svg>
            </span>
          </button>
        </div>
      </div>

      <!-- COL 3: Replacement + New Construction stacked -->
      <div class="flex flex-col gap-5">

        <!-- Replacement -->
        <div class="group rounded-2xl overflow-hidden border border-gray-100 bg-white shadow-sm hover:shadow-md transition-all duration-300 flex flex-col">
          <div class="overflow-hidden h-40">
            <img src={replacement.photo} alt={replacement.photoAlt}
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy"/>
          </div>
          <div class="p-5 flex flex-col flex-1">
            <h3 class="font-heading font-bold text-lg text-slate-900 mb-2">{replacement.title}</h3>
            <p class="text-slate-500 text-xs leading-relaxed mb-4 flex-1">{replacement.description}</p>
            <button data-modal="contact"
              class="w-full py-2 border border-gray-200 hover:border-slate-400 text-slate-700 text-sm font-semibold rounded-xl transition-all">
              Get Quote
            </button>
          </div>
        </div>

        <!-- New Construction -->
        <div class="group rounded-2xl overflow-hidden border border-gray-100 bg-white shadow-sm hover:shadow-md transition-all duration-300 flex flex-col">
          <div class="overflow-hidden h-40">
            <img src={newConstr.photo} alt={newConstr.photoAlt}
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy"/>
          </div>
          <div class="p-5 flex flex-col flex-1">
            <h3 class="font-heading font-bold text-lg text-slate-900 mb-2">{newConstr.title}</h3>
            <p class="text-slate-500 text-xs leading-relaxed mb-4 flex-1">{newConstr.description}</p>
            <button data-modal="contact"
              class="w-full py-2 border border-gray-200 hover:border-slate-400 text-slate-700 text-sm font-semibold rounded-xl transition-all">
              Get Quote
            </button>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
