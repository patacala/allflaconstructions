---
---

<section
  class="relative h-auto py-20 md:h-[700px] md:py-0 lg:h-[900px] overflow-visible"
  style="background-image: url('/hero.png'); background-size: cover; background-position: right center; background-repeat: no-repeat;"
>

  <!-- Content container -->
  <div class="max-w-7xl mx-auto px-6 h-full relative">
    <div class="grid grid-cols-1 lg:grid-cols-1 items-start h-full ">

      <!-- LEFT: Glass Card -->
      <div class="relative w-full max-w-2xl mt-40">

        <!-- Glass background layer (blur + gradient mask — fades to fully transparent on the right) -->
        <div
          class="absolute inset-0 rounded-3xl bg-gradient-to-r from-white/40 to-transparent backdrop-blur-lg border border-white/20 shadow-xl"
          style="-webkit-mask-image: linear-gradient(to right, black 45%, transparent 85%); mask-image: linear-gradient(to right, black 45%, transparent 85%);"
        ></div>

        <!-- Content layer (always fully visible, no mask) -->
        <div class="relative p-10">

          <!-- Badge -->
          <div class="bg-white/50 backdrop-blur text-xs rounded-full px-3 py-1 inline-flex items-center gap-2 mb-6 text-slate-700">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
            Trusted Roofing Experts
          </div>

          <!-- H1 -->
          <h1 class="text-5xl md:text-6xl font-heading font-bold leading-tight text-slate-900 mb-4">
            Expert Roofing for<br/>Florida's Toughest<br/>Conditions.
          </h1>

          <!-- Subtitle -->
          <p class="text-lg text-gray-600 mb-8 max-w-md">
            Our expert roofing services are designed to protect your property with quality and precision.
          </p>

          <!-- CTA -->
          <button
            data-modal="contact"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-900 hover:bg-slate-800 text-white font-semibold rounded-full transition-all"
          >
            Get Started Now
            <span class="w-6 h-6 rounded-full bg-blue-500 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 12h14m-7-7l7 7-7 7" />
              </svg>
            </span>
          </button>
        </div>
      </div>
      <!-- Review Chip — pill shape, glass, desktop only -->
      <div class="hidden lg:flex absolute bottom-20 right-10 z-20 bg-white/30 backdrop-blur-md rounded-full px-4 py-2 shadow-md items-center gap-2">
        <div class="flex -space-x-2">
          <div class="w-8 h-8 rounded-full border-2 border-white overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-slate-500 to-slate-800 flex items-center justify-center text-white text-xs font-bold">J</div>
          </div>
          <div class="w-8 h-8 rounded-full border-2 border-white overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-blue-400 to-blue-700 flex items-center justify-center text-white text-xs font-bold">M</div>
          </div>
          <div class="w-8 h-8 rounded-full border-2 border-white overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-orange-400 to-orange-700 flex items-center justify-center text-white text-xs font-bold">R</div>
          </div>
        </div>
        <div>
          <div class="flex items-center gap-0.5">
            {[...Array(5)].map(() => (
              <svg class="w-3 h-3 fill-yellow-400 text-yellow-400" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
            <span class="text-xs font-bold text-slate-800 ml-1">4.9/5</span>
          </div>
          <div class="text-slate-600 text-xs">Based on 240 Verified Reviews</div>
        </div>
      </div>

      <!-- RIGHT: empty — hero image is bg -->
    </div>

    <!-- Secondary floating card — static on mobile, absolute on lg (bleeds below hero) -->
    <div class="lg:absolute lg:left-6 lg:-bottom-16 lg:z-20 mt-6 lg:mt-0 w-[300px] bg-white shadow-2xl rounded-2xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="font-bold text-sm text-slate-900">Our Services</span>
        <div class="flex items-center gap-1 text-blue-500">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
      </div>
      <div class="flex gap-2 mb-3">
        <div class="w-14 h-14 rounded-xl bg-slate-200 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=100&q=80" alt="" class="w-full h-full object-cover"/>
        </div>
        <div class="w-14 h-14 rounded-xl bg-slate-200 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=100&q=80" alt="" class="w-full h-full object-cover"/>
        </div>
        <div class="w-14 h-14 rounded-xl bg-slate-200 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1621905251189-08b45d6a269e?auto=format&fit=crop&w=100&q=80" alt="" class="w-full h-full object-cover"/>
        </div>
      </div>
      <p class="text-slate-500 text-xs leading-relaxed mb-3">Repair, restoration, replacement and new construction for flat roofs across Florida.</p>
      <div class="flex flex-wrap gap-1.5">
        {['Repair', 'Restoration', 'Replacement'].map((s) => (
          <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-600 border border-slate-200">
            {s}
          </span>
        ))}
        <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-slate-900 text-white">
          New Construction
        </span>
      </div>
    </div>
  </div>

  

  <!-- Logo Bar — pegado al borde inferior derecho, solo esquina superior izquierda redondeada -->
  <div class="absolute bottom-0 right-0 z-10 w-[65%] max-w-[750px] bg-white rounded-tl-2xl shadow-xl py-5 overflow-hidden logo-bar">
    <!-- Fade masks on both edges -->
    <div class="absolute inset-y-0 left-0 w-16 z-10 pointer-events-none"
         style="background: linear-gradient(to right, white, transparent);"></div>
    <div class="absolute inset-y-0 right-0 w-16 z-10 pointer-events-none"
         style="background: linear-gradient(to left, white, transparent);"></div>

    <!-- Scrolling track -->
    <div class="logo-track flex items-center gap-14 w-max">
      <!-- Set 1 -->
      <div class="flex items-center gap-1.5 text-slate-400 shrink-0">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <span class="font-semibold text-sm tracking-tight">GAF Certified</span>
      </div>
      <div class="flex items-center gap-1.5 text-slate-400 shrink-0">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <span class="font-semibold text-sm tracking-tight">Florida Licensed</span>
      </div>
      <div class="flex items-center gap-1.5 text-slate-400 shrink-0">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <span class="font-semibold text-sm tracking-tight">BBB A+ Rated</span>
      </div>
      <div class="flex items-center gap-1.5 text-slate-400 shrink-0">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <span class="font-semibold text-sm tracking-tight">GAF Master Elite</span>
      </div>
      <div class="flex items-center gap-1.5 text-slate-400 shrink-0">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <span class="font-semibold text-sm tracking-tight">Licensed & Insured</span>
      </div>
      <!-- Set 2 (duplicate for seamless loop) -->
      <div class="flex items-center gap-1.5 text-slate-400 shrink-0">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <span class="font-semibold text-sm tracking-tight">GAF Certified</span>
      </div>
      <div class="flex items-center gap-1.5 text-slate-400 shrink-0">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <span class="font-semibold text-sm tracking-tight">Florida Licensed</span>
      </div>
      <div class="flex items-center gap-1.5 text-slate-400 shrink-0">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <span class="font-semibold text-sm tracking-tight">BBB A+ Rated</span>
      </div>
      <div class="flex items-center gap-1.5 text-slate-400 shrink-0">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <span class="font-semibold text-sm tracking-tight">GAF Master Elite</span>
      </div>
      <div class="flex items-center gap-1.5 text-slate-400 shrink-0">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <span class="font-semibold text-sm tracking-tight">Licensed & Insured</span>
      </div>
    </div>
  </div>

</section>

<style>
  @keyframes logo-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .logo-track {
    animation: logo-scroll 18s linear infinite;
  }
  .logo-bar:hover .logo-track {
    animation-play-state: paused;
  }
</style>
