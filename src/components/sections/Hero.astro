---
const stats = [
  { value: '10+', label: 'Years Experience' },
  { value: '500+', label: 'Projects Completed' },
  { value: '100%', label: 'Satisfaction Rate' },
];
---

<section
  class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden"
  style="background: linear-gradient(to bottom right, #0A0E1A, #0D1220);"
>
  <!-- Background grid pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");"></div>

  <!-- Ambient glow -->
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-orange-500/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-20 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Text content -->
      <div class="text-center lg:text-left">
        <!-- Top badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-orange-500/30 bg-orange-500/10 text-orange-300 text-sm font-medium mb-6">
          <span class="w-2 h-2 rounded-full bg-orange-400 animate-pulse"></span>
          Serving Your Area — Licensed & Insured
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-heading font-black text-white leading-[1.05] mb-6">
          Your Roof,
          <span class="block text-gradient">Protected by</span>
          Experts.
        </h1>

        <p class="text-gray-400 text-lg lg:text-xl leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
          Professional roofing solutions — installation, restoration, and repair — with premium materials and a workmanship guarantee you can count on.
        </p>

        <!-- Trust badges -->
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-3 mb-10">
          <div class="flex items-center gap-1.5 text-sm text-gray-300">
            <svg class="w-4 h-4 text-orange-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Licensed & Insured
          </div>
          <div class="w-px h-4 bg-brand-border"></div>
          <div class="flex items-center gap-1.5 text-sm text-gray-300">
            <svg class="w-4 h-4 text-orange-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            10+ Years Experience
          </div>
          <div class="w-px h-4 bg-brand-border"></div>
          <div class="flex items-center gap-1.5 text-sm text-gray-300">
            <svg class="w-4 h-4 text-orange-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Free Inspections
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <button
            data-modal="contact"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-orange-500 hover:bg-orange-400 text-white font-semibold rounded-xl transition-all duration-200 shadow-xl shadow-orange-500/30 hover:shadow-orange-500/50 active:scale-[0.98] text-lg w-full sm:w-auto"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Get Free Inspection
          </button>
          <a
            href="#gallery"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-gray-600 hover:border-orange-500 text-gray-200 hover:text-white font-semibold rounded-xl transition-all duration-200 hover:bg-white/5 text-lg w-full sm:w-auto"
          >
            View Our Work
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Visual card -->
      <div class="relative hidden lg:block">
        <!-- Main image placeholder / decorative card -->
        <div class="relative rounded-2xl overflow-hidden border border-brand-border shadow-2xl shadow-black/50">
          <!-- Placeholder for hero image — replace src with real photo -->
          <div class="aspect-[4/3] bg-gradient-to-br from-brand-dark to-brand-navy flex items-center justify-center">
            <div class="text-center">
              <svg class="w-20 h-20 text-gray-600 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                <polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1" points="9 22 9 12 15 12 15 22"/>
              </svg>
              <p class="text-gray-500 text-sm">Hero roofing image</p>
              <p class="text-gray-600 text-xs mt-1">Replace with actual photo</p>
            </div>
          </div>
          <!-- Overlay gradient at bottom -->
          <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-brand-navy/80 to-transparent"></div>
        </div>

        <!-- Floating review card -->
        <div class="absolute -bottom-6 -left-8 bg-brand-card rounded-xl p-4 border border-brand-border shadow-xl max-w-[220px]">
          <div class="flex items-center gap-1 mb-1.5">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-orange-400 fill-orange-400" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-white text-xs font-medium leading-snug">"Best roofing company we've worked with!"</p>
          <p class="text-gray-500 text-xs mt-1">— Maria G., Homeowner</p>
        </div>

        <!-- Floating stats badge -->
        <div class="absolute -top-4 -right-4 bg-orange-500 rounded-xl p-4 shadow-xl shadow-orange-500/30">
          <div class="text-white font-heading font-black text-2xl leading-none">500+</div>
          <div class="text-orange-100 text-xs font-medium">Projects Done</div>
        </div>
      </div>
    </div>

    <!-- Stats row (mobile: shown; desktop: shown below) -->
    <div class="mt-16 pt-10 border-t border-brand-border grid grid-cols-3 gap-6 lg:gap-12 max-w-lg mx-auto lg:max-w-none">
      {stats.map(({ value, label }) => (
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-heading font-black text-gradient mb-1">{value}</div>
          <div class="text-gray-400 text-sm">{label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
