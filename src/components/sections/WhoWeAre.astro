---
---

<section id="who-we-are" class="bg-white py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Top bar: badge left, CTA right -->
    <div class="flex items-center justify-between mb-4">
      <div class="inline-flex items-center gap-2 text-sm text-slate-500">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
        Who We Are
      </div>
      <button
        data-modal="contact"
        class="inline-flex items-center gap-2 pl-5 pr-1.5 py-1.5 border border-gray-200 bg-white rounded-full text-sm font-medium text-slate-800 hover:border-slate-300 transition-all"
      >
        Read More
        <span class="w-7 h-7 rounded-full bg-blue-500 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </span>
      </button>
    </div>

    <hr class="border-gray-200 mb-12" />

    <!-- Main grid: left ~35%, right ~65% -->
    <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-10 lg:gap-14">

      <!-- LEFT: big image + stat below -->
      <div class="flex flex-col">
        <div class="rounded-2xl overflow-hidden flex-1">
          <img
            src="/block1.jpeg"
            alt="Alfla roofer working on a roof"
            class="w-full h-[360px] lg:h-[440px] object-cover"
            loading="lazy"
          />
        </div>
        <div class="mt-6">
          <p class="text-2xl font-heading font-bold text-slate-900">240+ Satisfied Clients</p>
          <p class="text-slate-500 text-sm mt-1">Florida homeowners and property managers who trust us.</p>
        </div>
      </div>

      <!-- RIGHT: paragraph top + image+text+stats bottom -->
      <div class="flex flex-col gap-8">

        <!-- Large paragraph -->
        <p class="text-2xl lg:text-3xl text-slate-700 leading-snug font-light">
          At All Florida Construction &amp; Roofing, we specialize in reliable flat roof repairs, restorations, and replacements for residential and commercial properties across all of Florida. With high-quality materials &amp; skilled craftsmanship.
        </p>

        <!-- Bottom row: second image left, text+stats right -->
        <div class="grid grid-cols-1 sm:grid-cols-[1.2fr_1fr] gap-8 items-end">

          <!-- Second image -->
          <div class="rounded-2xl overflow-hidden">
            <img
              src="/block1-2.jpg"
              alt="Alfla roofing specialist on site"
              class="w-full h-[280px] object-cover"
              loading="lazy"
            />
          </div>

          <!-- Text + stats -->
          <div class="flex flex-col justify-end gap-6">
            <p class="text-slate-500 text-base leading-relaxed">
              Trust our experienced team to keep your property safe, resilient, and well-protected — no matter the weather.
            </p>
            <hr class="border-gray-200" />
            <!-- Stats -->
            <div class="flex items-start gap-6">
              <div class="text-center">
                <p class="text-4xl font-bold text-slate-900 leading-none">92%</p>
                <span class="mt-2 inline-block px-3 py-1 rounded-full border border-gray-200 bg-white text-slate-600 text-xs font-medium">
                  Client Satisfaction
                </span>
              </div>
              <div class="text-center">
                <p class="text-4xl font-bold text-slate-900 leading-none">98%</p>
                <span class="mt-2 inline-block px-3 py-1 rounded-full border border-gray-200 bg-white text-slate-600 text-xs font-medium">
                  Project Completion
                </span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>
</section>
