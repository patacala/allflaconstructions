---
const steps = [
  {
    n: '01',
    title: 'Free Inspection',
    description: 'We assess your flat roof at no cost — no obligation. You\'ll receive a full report with photos and honest recommendations.',
    img: 'https://images.unsplash.com/photo-1586769852836-bc069f19e1b6?auto=format&fit=crop&w=300&q=80',
    imgAlt: 'Inspector reviewing roof',
  },
  {
    n: '02',
    title: 'Custom Quote',
    description: 'Transparent, itemized pricing delivered in 24 hours. We explain every option and recommend the best fit for your budget — no hidden fees.',
    img: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=300&q=80',
    imgAlt: 'Reviewing roofing quote',
  },
  {
    n: '03',
    title: 'Expert Installation',
    description: 'Our licensed crew completes the work efficiently. Clean site, guaranteed quality, and you\'re back to normal fast.',
    img: 'https://images.unsplash.com/photo-1621905251189-08b45d6a269e?auto=format&fit=crop&w=300&q=80',
    imgAlt: 'Expert roofing installation',
  },
];
---

<section id="process" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- LEFT: contained image, all corners rounded -->
      <div class="rounded-3xl overflow-hidden">
        <img
          src="/trust1.jpg"
          alt="Professional roofer working on flat roof"
          class="w-full h-[480px] lg:h-[560px] object-cover"
          loading="lazy"
        />
      </div>

      <!-- RIGHT: content + accordion -->
      <div>

        <!-- Badge -->
        <div class="inline-flex items-center gap-2 text-sm text-slate-500 mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
          How It Works
        </div>

        <!-- Heading -->
        <h2 class="text-4xl lg:text-5xl font-heading font-bold text-slate-900 mb-4 leading-tight">
          Trusted Hands for Your<br/> Roof's Protection.
        </h2>
        <p class="text-slate-500 mb-10 leading-relaxed">
          From your first call to a weatherproof roof — we've made the process fast, transparent, and stress-free.
        </p>

        <!-- Accordion -->
        <div class="divide-y divide-gray-100 border-t border-gray-100" id="process-accordion">
          {steps.map(({ n, title, description, img, imgAlt }, i) => (
            <div class="process-item" data-index={i}>
              <button
                class="w-full flex items-center justify-between py-5 text-left group"
                aria-expanded={i === 0 ? 'true' : 'false'}
              >
                <div class="flex items-center gap-3">
                  <span class="inline-flex items-center justify-center w-8 h-6 rounded bg-slate-100 text-slate-500 font-mono text-xs font-semibold">{n}</span>
                  <span class="font-heading font-bold text-lg text-slate-900">{title}</span>
                </div>
                <svg class={`w-4 h-4 text-slate-400 transition-transform duration-300 ${i === 0 ? 'rotate-45' : ''}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
              </button>

              <!-- Body: text left, image right -->
              <div class={`process-body pb-6 ${i !== 0 ? 'hidden' : ''}`}>
                <div class="flex gap-5 items-start">
                  <p class="text-slate-500 text-sm leading-relaxed flex-1">{description}</p>
                  <img
                    src={img}
                    alt={imgAlt}
                    class="w-32 h-24 rounded-xl object-cover flex-shrink-0"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <div class="mt-10">
          <button
            data-modal="contact"
            class="inline-flex items-center gap-2 px-7 py-3.5 bg-slate-900 hover:bg-slate-800 text-white font-semibold rounded-full transition-all"
          >
            Schedule Free Inspection
            <span class="w-6 h-6 rounded-full bg-blue-500 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 12h14m-7-7l7 7-7 7"/>
              </svg>
            </span>
          </button>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  const accordion = document.getElementById('process-accordion');
  if (accordion) {
    accordion.querySelectorAll('.process-item button').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.process-item') as HTMLElement;
        const body = item.querySelector('.process-body') as HTMLElement;
        const icon = btn.querySelector('svg') as SVGElement;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        // Close all
        accordion.querySelectorAll('.process-item').forEach((i) => {
          const b = i.querySelector('.process-body') as HTMLElement;
          const bt = i.querySelector('button') as HTMLElement;
          const ic = bt.querySelector('svg') as SVGElement;
          b.classList.add('hidden');
          bt.setAttribute('aria-expanded', 'false');
          ic.classList.remove('rotate-45');
        });

        // Open clicked if it was closed
        if (!isOpen) {
          body.classList.remove('hidden');
          btn.setAttribute('aria-expanded', 'true');
          icon.classList.add('rotate-45');
        }
      });
    });
  }
</script>
