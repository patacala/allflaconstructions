---
const badges = [
  'Miami-Dade Licensed',
  'Fully Insured',
  'Miami-Dade Certified',
  'BBB Accredited',
  '500+ Projects Completed',
  'Free Inspections',
];
---

<section class="bg-brand-navy py-5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
      {badges.map((badge) => (
        <div class="flex items-center gap-2 text-sm text-slate-300">
          <svg class="w-4 h-4 text-brand-orange flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          {badge}
        </div>
      ))}
    </div>
  </div>
</section>
