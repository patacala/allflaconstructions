---
const trustPoints = [
  'Licensed & fully insured',
  'Free, no-obligation inspection',
  'Upfront pricing — no hidden fees',
  'Workmanship guarantee included',
];
---

<section class="py-20 lg:py-32 bg-brand-dark relative overflow-hidden">
  <!-- Background glow -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="w-[800px] h-[400px] bg-orange-500/8 rounded-full blur-[100px]"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <!-- Urgency label -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-orange-500/30 bg-orange-500/10 text-orange-300 text-sm font-medium mb-8">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
      </svg>
      Limited inspection slots available this month
    </div>

    <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-black text-white leading-tight mb-6">
      Your Roof Deserves
      <span class="text-gradient block">Expert Attention</span>
    </h2>

    <p class="text-gray-400 text-lg leading-relaxed mb-10 max-w-2xl mx-auto">
      Don't wait for a small problem to become an expensive disaster. Schedule your free inspection today and get a complete picture of your roof's condition — with zero obligation.
    </p>

    <!-- Trust checklist -->
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mb-10">
      {trustPoints.map((point) => (
        <div class="flex items-center gap-2 text-sm text-gray-300">
          <svg class="w-4 h-4 text-orange-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          {point}
        </div>
      ))}
    </div>

    <!-- Primary CTA -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <button
        data-modal="contact"
        class="inline-flex items-center justify-center gap-2 px-10 py-5 bg-orange-500 hover:bg-orange-400 text-white font-bold rounded-2xl transition-all duration-200 shadow-2xl shadow-orange-500/35 hover:shadow-orange-500/50 active:scale-[0.98] text-xl w-full sm:w-auto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Schedule Free Inspection
      </button>
      <a
        href="tel:+15550000000"
        class="inline-flex items-center justify-center gap-2 px-8 py-5 border border-gray-600 hover:border-orange-500/50 text-gray-200 hover:text-white font-semibold rounded-2xl transition-all duration-200 hover:bg-white/5 text-lg w-full sm:w-auto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call (555) 000-0000
      </a>
    </div>

    <p class="text-gray-500 text-sm mt-6">We respond within 24 hours — usually within the hour.</p>
  </div>
</section>
