---
import SectionHeader from '../ui/SectionHeader.astro';

const testimonials = [
  {
    name: 'James & Patricia H.',
    city: 'North District',
    rating: 5,
    quote: 'Alfla Constructions replaced our entire roof after storm damage. The crew was professional, fast, and the result is beautiful. They handled everything — even the insurance paperwork.',
    service: 'Full Roof Replacement',
    initials: 'JP',
  },
  {
    name: 'Carlos M.',
    city: 'Westside',
    rating: 5,
    quote: 'Called them for a free inspection and they found issues I had no idea about. No pressure, just honest advice. Had them do the repair and it was done in one day. Excellent work.',
    service: 'Roof Repair',
    initials: 'CM',
  },
  {
    name: 'Linda & Tom R.',
    city: 'Oakwood',
    rating: 5,
    quote: 'We got three quotes and Alfla was not the cheapest — but they were clearly the most professional. Two years later, the roof looks perfect. Worth every penny.',
    service: 'New Installation',
    initials: 'LT',
  },
  {
    name: 'Sandra P.',
    city: 'South Bay',
    rating: 5,
    quote: 'I was nervous about a big roofing job but the team made it so easy. Clear communication, on-time arrival, and they left my yard cleaner than they found it. Will 100% recommend.',
    service: 'Roof Restoration',
    initials: 'SP',
  },
  {
    name: 'Mike D.',
    city: 'Heritage Heights',
    rating: 5,
    quote: 'Emergency repair after a bad storm. They were out the next morning, identified the issue within minutes, and had it patched the same day. Lifesavers.',
    service: 'Emergency Repair',
    initials: 'MD',
  },
  {
    name: 'Rosa G.',
    city: 'Eastview',
    rating: 5,
    quote: 'The free inspection was thorough and detailed. They showed me photos of every issue and explained everything clearly. Very trustworthy company — they\'ve earned a customer for life.',
    service: 'Inspection & Repair',
    initials: 'RG',
  },
];
---

<section id="testimonials" class="py-20 lg:py-32 bg-brand-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Header with Google rating -->
    <div class="text-center mb-12 lg:mb-16">
      <span class="inline-block text-orange-400 text-sm font-semibold tracking-widest uppercase mb-3">
        Client Reviews
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-white leading-tight mb-4">
        Don't Take Our Word
        <span class="text-gradient"> For It</span>
      </h2>
      <!-- Aggregate rating -->
      <div class="flex items-center justify-center gap-3 mt-4">
        <div class="flex items-center gap-1">
          {[...Array(5)].map(() => (
            <svg class="w-5 h-5 text-orange-400 fill-orange-400" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="text-white font-bold text-xl">5.0</span>
        <span class="text-gray-400 text-sm">· 120+ Google Reviews</span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map(({ name, city, rating, quote, service, initials }) => (
        <div class="group p-6 rounded-2xl border border-brand-border hover:border-orange-500/30 bg-brand-navy hover:bg-brand-navy/80 transition-all duration-300 flex flex-col">
          <!-- Stars -->
          <div class="flex items-center gap-0.5 mb-4">
            {[...Array(rating)].map(() => (
              <svg class="w-4 h-4 text-orange-400 fill-orange-400" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-gray-300 text-sm leading-relaxed mb-6 flex-1">
            "{quote}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-brand-border">
            <div class="w-10 h-10 rounded-full bg-orange-500/20 border border-orange-500/30 flex items-center justify-center text-orange-400 font-bold text-sm flex-shrink-0">
              {initials}
            </div>
            <div>
              <p class="text-white font-semibold text-sm">{name}</p>
              <p class="text-gray-500 text-xs">{city} · {service}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
