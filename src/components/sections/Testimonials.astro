---
const sideTestimonials = [
  {
    name: 'Carlos M.',
    role: 'Warehouse Owner, Doral',
    quote: 'They inspected our roof and gave a fair estimate. No hidden costs, just excellent work.',
    avatarUrl: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=80&q=80',
  },
  {
    name: 'Maria G.',
    role: 'Property Manager, Hialeah',
    quote: 'The quality of materials and attention to detail were impressive. Worth every penny.',
    avatarUrl: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=80&q=80',
  },
  {
    name: 'Robert T.',
    role: 'Homeowner, Miami Lakes',
    quote: 'They provided a fair quote and delivered exceptional results. My home feels safer now.',
    avatarUrl: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=80&q=80',
  },
  {
    name: 'Sandra L.',
    role: 'Business Owner, Kendall',
    quote: 'The communication was smooth, and they made sure I was happy with the result after work.',
    avatarUrl: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=80&q=80',
  },
];

const featured = {
  name: 'James Rivera',
  role: 'CEO, Rivera Properties',
  quote: 'Quick to respond, reliable in service, and unmatched in roofing excellence — that\'s Alfla\'s promise and they deliver on it every time.',
  photoUrl: 'https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&w=400&q=80',
};
---

<section id="testimonials" class="py-24 lg:py-32 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="text-center mb-4">
      <div class="inline-flex items-center gap-2 text-sm text-slate-500 mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
        Our Testimonial
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-slate-900 leading-tight">
        What Our Clients Say About Us
      </h2>
    </div>
    <hr class="border-gray-200 mb-12 lg:mb-16" />

    <!-- 3-column grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:items-stretch">

      <!-- Left: 2 stacked cards -->
      <div class="flex flex-col gap-6 h-full">
        {sideTestimonials.slice(0, 2).map(({ name, role, quote, avatarUrl }) => (
          <div class="flex-1 bg-white rounded-2xl border border-gray-100 shadow-sm p-6 flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <img src={avatarUrl} alt={name} class="w-11 h-11 rounded-full object-cover flex-shrink-0" loading="lazy" />
              <div>
                <p class="font-semibold text-slate-900 text-sm leading-tight">{name}</p>
                <p class="text-slate-400 text-xs">{role}</p>
              </div>
            </div>
            <hr class="border-gray-100 mb-4" />
            <p class="text-slate-600 text-sm leading-relaxed flex-1">"{quote}"</p>
          </div>
        ))}
      </div>

      <!-- Center: featured card -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden flex flex-col">
        <!-- Portrait photo -->
        <div class="w-full h-64 overflow-hidden">
          <img
            src={featured.photoUrl}
            alt={featured.name}
            class="w-full h-full object-cover object-top"
            loading="lazy"
          />
        </div>
        <div class="p-6 flex flex-col flex-1">
          <p class="text-slate-400 text-xs mb-1">{featured.role}</p>
          <p class="text-slate-700 text-sm leading-relaxed mb-6 flex-1">"{featured.quote}"</p>
          <!-- Stats -->
          <div class="flex items-start gap-10 pt-4 border-t border-gray-100">
            <div>
              <p class="text-3xl font-bold text-slate-900">98%</p>
              <p class="text-xs text-slate-400 mt-0.5">Our Client Satisfaction</p>
            </div>
            <div>
              <p class="text-3xl font-bold text-slate-900">4+</p>
              <p class="text-xs text-slate-400 mt-0.5">Years of Experience</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: 2 stacked cards -->
      <div class="flex flex-col gap-6 h-full">
        {sideTestimonials.slice(2, 4).map(({ name, role, quote, avatarUrl }) => (
          <div class="flex-1 bg-white rounded-2xl border border-gray-100 shadow-sm p-6 flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <img src={avatarUrl} alt={name} class="w-11 h-11 rounded-full object-cover flex-shrink-0" loading="lazy" />
              <div>
                <p class="font-semibold text-slate-900 text-sm leading-tight">{name}</p>
                <p class="text-slate-400 text-xs">{role}</p>
              </div>
            </div>
            <hr class="border-gray-100 mb-4" />
            <p class="text-slate-600 text-sm leading-relaxed flex-1">"{quote}"</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
