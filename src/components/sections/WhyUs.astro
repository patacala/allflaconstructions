---
const differentiators = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: 'Licensed & Fully Insured',
    description: 'Florida-licensed and fully insured. Your property and peace of mind are completely protected on every job.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: '13+ Years Across Florida',
    description: 'Over a decade serving clients across all of Florida. We know what flat roofs in this climate need to survive.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
    title: '15-Year Warranty',
    description: 'Every restoration comes with a 15-year manufacturer warranty. We back our work in writing, guaranteed.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: 'Transparent Pricing',
    description: 'No surprises, no hidden fees. We give you an itemized quote and explain every line item before work begins.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: 'Fast Turnaround',
    description: 'Most restorations completed in a single day. We respect your operations and minimize disruption to your property.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
    title: 'Florida Code Compliant',
    description: 'All our work meets Florida Building Code and wind uplift requirements. Permits handled, inspections passed.',
  },
];
---

<section id="why-us" class="py-24 lg:py-32 bg-[#0B1F4B]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="text-center mb-12 lg:mb-14">
      <div class="inline-flex items-center gap-2 text-sm text-blue-300 mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>
        Why Choose Us
      </div>
      <h2 class="text-4xl lg:text-5xl font-heading font-bold text-white leading-tight mb-4">
        The All Florida Difference
      </h2>
      <p class="text-white/60 text-lg max-w-2xl mx-auto">
        We don't just fix roofs — we solve problems for Florida property owners who need someone they can trust.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {differentiators.map(({ icon, title, description }) => (
        <div class="group p-6 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/10 hover:border-blue-400/40 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-white/10 border border-white/10 flex items-center justify-center text-white/70 mb-5 group-hover:bg-blue-500 group-hover:text-white group-hover:border-blue-500 transition-all duration-300">
            <span set:html={icon} />
          </div>
          <h3 class="font-heading font-bold text-white text-lg mb-2">{title}</h3>
          <p class="text-white/55 text-sm leading-relaxed">{description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
