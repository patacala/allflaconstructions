---
import SectionHeader from '../ui/SectionHeader.astro';

const faqs = [
  {
    question: 'How long does a roof replacement take?',
    answer: 'Most residential roof replacements take 1–3 days depending on the size and complexity of the project. We work efficiently without rushing — quality is our priority. We\'ll give you a precise timeline during your free consultation.',
  },
  {
    question: 'How much does a new roof cost?',
    answer: 'Costs vary based on roof size, pitch, material choice, and any underlying repairs needed. Most residential projects range from $8,000 to $25,000. We provide detailed, itemized quotes so you know exactly what you\'re paying for — no surprises.',
  },
  {
    question: 'Do you offer financing?',
    answer: 'Yes! We work with financing partners to offer flexible payment plans. Many homeowners can start their project with little to no money down. Ask about our current financing options during your free inspection.',
  },
  {
    question: 'Is my roof covered by homeowner\'s insurance?',
    answer: 'Storm damage, hail, and wind damage are typically covered by homeowner\'s insurance. We\'ll help document the damage and provide the detailed reports your insurance company needs. We\'ve helped hundreds of homeowners navigate the claims process.',
  },
  {
    question: 'What warranty do you provide?',
    answer: 'We offer a workmanship warranty on all installations, plus manufacturer warranties on materials. Depending on the product, material warranties range from 25 years to lifetime coverage. Full warranty details are provided in writing before any work begins.',
  },
  {
    question: 'What roofing materials do you work with?',
    answer: 'We install asphalt shingles, metal roofing, tile, flat/TPO roofing systems, and more. During your inspection, we\'ll recommend the best material for your home\'s style, climate, and budget.',
  },
  {
    question: 'Do I need to be home during the work?',
    answer: 'Not necessarily. While we appreciate homeowners being available for the initial walkthrough and final inspection, our crews can work independently once the project is underway. We\'ll keep you updated with photos and daily progress reports.',
  },
  {
    question: 'How do I know if I need a repair or full replacement?',
    answer: 'That\'s exactly what our free inspection is for! Our inspector will honestly assess whether a repair or replacement makes more financial sense for your situation. We\'ll never recommend more work than necessary.',
  },
];
---

<section id="faq" class="py-20 lg:py-32 bg-brand-navy">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <SectionHeader
      label="FAQ"
      title="Common Questions"
      titleHighlight="Answered"
      subtitle="Have more questions? Call us or request your free inspection and we'll address everything."
    />

    <div class="space-y-3" id="faq-list">
      {faqs.map(({ question, answer }, index) => (
        <div
          class="faq-item border border-brand-border hover:border-orange-500/30 rounded-xl overflow-hidden transition-colors duration-200"
          data-index={index}
        >
          <button
            class="faq-trigger w-full flex items-center justify-between gap-4 px-6 py-5 text-left group"
            aria-expanded="false"
          >
            <span class="text-white font-medium group-hover:text-orange-300 transition-colors pr-4">
              {question}
            </span>
            <svg
              class="faq-icon w-5 h-5 text-orange-400 flex-shrink-0 transition-transform duration-300"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer hidden px-6 pb-5">
            <p class="text-gray-400 text-sm leading-relaxed border-t border-brand-border pt-4">
              {answer}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Still have questions? -->
    <div class="mt-12 p-6 rounded-2xl border border-orange-500/20 bg-orange-500/5 text-center">
      <h3 class="text-white font-semibold text-lg mb-2">Still have questions?</h3>
      <p class="text-gray-400 text-sm mb-5">Our team is happy to answer anything. Reach out directly — no bots, no runaround.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="tel:+15550000000"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-brand-border hover:border-orange-500/50 text-gray-300 hover:text-white font-medium rounded-lg transition-all hover:bg-white/5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (555) 000-0000
        </a>
        <button
          data-modal="contact"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-orange-500 hover:bg-orange-400 text-white font-semibold rounded-lg transition-colors shadow-lg shadow-orange-500/20"
        >
          Get Free Inspection
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const triggers = document.querySelectorAll('.faq-trigger');

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const icon = trigger.querySelector('.faq-icon');
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all open items
      document.querySelectorAll('.faq-item').forEach((el) => {
        el.querySelector('.faq-answer')?.classList.add('hidden');
        el.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
        el.querySelector('.faq-icon')?.classList.remove('rotate-180');
      });

      // If was closed, open this one
      if (!isOpen) {
        answer?.classList.remove('hidden');
        trigger.setAttribute('aria-expanded', 'true');
        icon?.classList.add('rotate-180');
      }
    });
  });
</script>
