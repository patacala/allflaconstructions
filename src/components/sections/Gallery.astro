---
import SectionHeader from '../ui/SectionHeader.astro';

// Placeholder gallery items — replace with real photos
const galleryItems = [
  { label: 'Residential Re-Roof', location: 'North District', type: 'replacement' },
  { label: 'Commercial Flat Roof', location: 'Business Center', type: 'installation' },
  { label: 'Storm Damage Repair', location: 'Westside Homes', type: 'repair' },
  { label: 'Full Restoration', location: 'Heritage Heights', type: 'restoration' },
  { label: 'New Construction', location: 'Oakwood Estates', type: 'installation' },
  { label: 'Tile Replacement', location: 'South Bay', type: 'replacement' },
];
---

<section id="gallery" class="py-20 lg:py-32 bg-brand-navy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <SectionHeader
      label="Our Work"
      title="Results That Speak"
      titleHighlight="For Themselves"
      subtitle="Every project is a testament to our commitment to quality. Browse our recent work across residential and commercial properties."
    />

    <!-- Gallery grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
      {galleryItems.map(({ label, location, type }, index) => (
        <div class={`group relative overflow-hidden rounded-2xl border border-brand-border hover:border-orange-500/40 transition-all duration-300 cursor-pointer ${index === 0 ? 'sm:col-span-2 lg:col-span-1' : ''}`}>
          <!-- Image placeholder -->
          <div class="aspect-video bg-gradient-to-br from-brand-card to-brand-dark flex items-center justify-center">
            <div class="text-center">
              <svg class="w-12 h-12 text-gray-600 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <p class="text-gray-600 text-xs">Replace with project photo</p>
            </div>
          </div>

          <!-- Overlay on hover -->
          <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/90 via-brand-navy/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

          <!-- Info -->
          <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
            <div class="flex items-center gap-2 mb-1">
              <span class={`px-2 py-0.5 rounded-full text-xs font-medium capitalize ${
                type === 'installation' ? 'bg-blue-500/20 text-blue-300' :
                type === 'replacement' ? 'bg-orange-500/20 text-orange-300' :
                type === 'restoration' ? 'bg-green-500/20 text-green-300' :
                'bg-purple-500/20 text-purple-300'
              }`}>
                {type}
              </span>
            </div>
            <p class="text-white font-semibold text-sm">{label}</p>
            <p class="text-gray-400 text-xs">{location}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <button
        data-modal="contact"
        class="inline-flex items-center gap-2 px-6 py-3 border border-brand-border hover:border-orange-500/50 text-gray-300 hover:text-white font-medium rounded-xl transition-all duration-200 hover:bg-white/5"
      >
        Want results like these? Let's talk
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </button>
    </div>
  </div>
</section>
